{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/sfs-sync.sh\"",
            "timeout": 30,
            "statusMessage": "sfs: pulling latest files"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/sfs-sync.sh\"",
            "async": true
          }
        ]
      }
    ]
  }
}
