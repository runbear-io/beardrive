{
  "permissions": {
    "allow": [
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go run ./cmd/bdrive:*)",
      "Bash(gofmt:*)",
      "Bash(go mod tidy)",
      "Bash(go doc:*)",
      "Bash(go env:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-arch-diagrams.sh"
          }
        ]
      }
    ]
  }
}
